                    </div>
                </div>

                <a href="#contact" class="btn btn-dark btn-lg mt-4 px-5 rounded-0">Book a Tasting</a>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container py-5 text-center">
        <h2 class="mb-5 display-5">Our Signature <strong>Specialties</strong></h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="service-card">
                    <div class="service-icon"><i class="fas fa-fire-burner"></i></div>
                    <h3>Live Kitchens</h3>
                    <p>Interactive stations featuring piping hot Jalebis, artisanal Chaats, and global Stir-fry.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="service-card">
                    <div class="service-icon"><i class="fas fa-wine-glass"></i></div>
                    <h3>Signature Drinks</h3>
                    <p>Exotic mocktails and traditional cooling beverages served with a royal flair.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="service-card">
                    <div class="service-icon"><i class="fas fa-mortar-pestle"></i></div>
                    <h3>Mass Catering</h3>
                    <p>The expertise to serve thousands of guests with consistent quality and unmatched hygiene.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="py-5" style="background: var(--royal-maroon);">
    <div class="container text-white py-5">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-5 mb-lg-0">
                <h2 class="display-4 fw-bold">Ready to Host <br><span style="color: var(--gold-accent);">A Grand Feast?</span></h2>
                <p class="lead opacity-75">Connect with our event consultants to discuss your guest count, menu preferences, and pricing packages.</p>
                
                <div class="mt-5">
                    <p class="mb-2"><i class="fas fa-envelope-open me-2 text-warning"></i> events@heritagecaterers.com</p>
                    <p><i class="fas fa-phone-volume me-2 text-warning"></i> +91 98765 43210</p>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="bg-white p-5 shadow text-dark">
                    <h3 class="mb-4">Get a Personalized Quote</h3>
                    <form class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" class="form-control rounded-0" placeholder="e.g. Rahul Verma">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Mobile Number</label>
                            <input type="tel" class="form-control rounded-0" placeholder="+91">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Event Date</label>
                            <input type="date" class="form-control rounded-0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Estimated Guests</label>
                            <select class="form-select rounded-0">
                                <option>200 - 500</option>
                                <option>500 - 1000</option>
                                <option>1000+</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <button class="btn-premium w-100 py-3">Submit Inquiry</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script>

    let slides = document.querySelectorAll(".hero-slider img");
    let index = 0;

    function changeSlide(){
        slides[index].classList.remove("active");
        index = (index + 1) % slides.length;
        slides[index].classList.add("active");
    }

    setInterval(changeSlide, 4000); // 4 sec me change

</script>