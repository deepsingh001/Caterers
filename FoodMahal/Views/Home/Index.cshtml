@{
    ViewData["Title"] = "Heritage Caterers | Artisanal Wedding Feasts";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,500&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    :root {
        --heritage-orange: #E67E22; /* Premium Saffron */
        --royal-maroon: #4A0404;
        --gold-accent: #C5A02B;
        --ivory: #FCF9F2;
        --charcoal: #2C3E50;
    }

    .food-item-card img {
        transition: 0.5s;
    }

    .food-item-card:hover img {
        transform: scale(1.1);
    }

    /* HERO IMAGE SLIDER */

    .hero-slider {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

        .hero-slider img {
            position: absolute;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: opacity 1s ease-in-out;
        }

            .hero-slider img.active {
                opacity: 0.5;
            }

    .hero-slider img {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

        .hero-slider img.active {
            opacity: 0.5;
        }

    body { font-family: 'Montserrat', sans-serif; background: #ffffff; color: var(--charcoal); }
    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 700; }

    /* Hero Branding */
    .hero-container {
        position: relative; height: 85vh; display: flex; align-items: center;
        background: #000; overflow: hidden;
    }

    .hero-overlay-img {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        object-fit: cover; opacity: 0.5;
    }

    .hero-content {
        position: relative; z-index: 5; color: white; text-align: center; width: 100%;
    }

    .hero-content h1 { font-size: clamp(40px, 7vw, 85px); margin-bottom: 15px; }
    .hero-content span { color: var(--heritage-orange); font-style: italic; }

    /* Service Cards */
    .service-card {
        background: var(--ivory); padding: 50px 30px; border-radius: 4px;
        transition: all 0.4s ease; border-top: 4px solid var(--royal-maroon);
        height: 100%;
    }

    .service-card:hover { 
        transform: translateY(-12px); 
        background: var(--royal-maroon); 
        color: white; 
    }

    .service-icon { font-size: 50px; color: var(--heritage-orange); margin-bottom: 25px; }

    /* Featured Dish Section */
    .culinary-showcase { padding: 100px 0; background: #fff; }
    
    .signature-img {
        width: 100%; height: 400px; object-fit: cover; border-radius: 8px;
        box-shadow: 25px 25px 0px var(--ivory);
    }

    /* Professional Buttons */
    .btn-premium {
        background: var(--royal-maroon); color: white; border: none;
        padding: 16px 40px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 2px; transition: 0.3s; border-radius: 0;
        text-decoration: none; display: inline-block;
    }

    .btn-premium:hover { background: var(--heritage-orange); color: white; box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

    /* Menu Gallery */
    .food-item-card {
        border: none; border-radius: 0; overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }

    .food-item-card img { transition: 0.5s; }
    .food-item-card:hover img { transform: scale(1.1); 
    .hero-slider img{
    position:absolute;
    width:100%;
    height:100%;
    object-fit:cover;
    opacity:0;
    transition:opacity 1s ease-in-out;
}

.hero-slider img.active{
    opacity:0.5;
}
    }
</style>

<section class="hero-container">

    <div class="hero-slider">

        <img src="https://images.unsplash.com/photo-1555243821-208b393967bc?auto=format&fit=crop&w=1920" class="active">

        <img src="https://images.unsplash.com/photo-1606787366850-de6330128bfc?auto=format&fit=crop&w=1920">

        <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=1920">

        <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?auto=format&fit=crop&w=1920">

        <img src="https://images.unsplash.com/photo-1555243896-c709bfa0b564?auto=format&fit=crop&w=1920">

    </div>

    <div class="container hero-content">
        <div class="mb-3 text-uppercase" style="letter-spacing: 5px; color: var(--gold-accent);">Established 1998</div>
        <h1>The Art of <span>Gourmet Catering</span></h1>
        <p class="lead mb-5" style="max-width: 700px; margin: 0 auto; opacity: 0.9;">
            Crafting legendary culinary experiences for grand weddings and intimate celebrations.
        </p>
        <div>
            <a href="#contact" class="btn-premium">Request a Quote</a>
            <a href="#menu" class="btn btn-outline-light ms-lg-3 p-3 px-5 rounded-0">View Menu</a>
        </div>
    </div>

</section>

<section class="py-5" style="background: var(--royal-maroon); color: var(--gold-accent);">
    <div class="container text-center">
        <div class="row g-4">
            <div class="col-md-3"> <h2 class="mb-1">3.5k+</h2> <p class="small text-uppercase mb-0 text-white">Events Managed</p> </div>
            <div class="col-md-3"> <h2 class="mb-1">100%</h2> <p class="small text-uppercase mb-0 text-white">Pure Vegetarian</p> </div>
            <div class="col-md-3"> <h2 class="mb-1">75+</h2> <p class="small text-uppercase mb-0 text-white">Master Chefs</p> </div>
            <div class="col-md-3"> <h2 class="mb-1">50+</h2> <p class="small text-uppercase mb-0 text-white">Signature Cuisines</p> </div>
        </div>
    </div>
</section>

<section class="culinary-showcase">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?auto=format&fit=crop&w=800" class="signature-img" alt="Craftsmanship">
            </div>
            <div class="col-lg-6 ps-lg-5 mt-5 mt-lg-0">
                <span class="text-uppercase" style="color: var(--heritage-orange); letter-spacing: 3px;">Our Legacy</span>
